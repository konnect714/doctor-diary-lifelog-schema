{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doctordiary.kr/schemas/exercise/1.0.0.json",
  "title": "Doctor Diary Exercise Event",
  "type": "object",
  "required": [
    "event_id",
    "user_id_hash",
    "event_start",
    "event_end",
    "duration_min",
    "activity_type",
    "intensity",
    "input_method",
    "schema_version"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "event_id": {"type": "string", "pattern": "^ex_[A-Za-z0-9_-]+$"},
    "user_id_hash": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "event_start": {"type": "string", "format": "date-time"},
    "event_end": {"type": "string", "format": "date-time"},
    "duration_min": {"type": "number", "minimum": 0, "maximum": 1440},
    "activity_type": {
      "type": "string",
      "enum": [
        "walking",
        "running",
        "cycling",
        "hiking",
        "swimming",
        "yoga",
        "pilates",
        "weight_training",
        "elliptical",
        "climbing",
        "dancing",
        "golf",
        "tennis",
        "badminton",
        "home_workout",
        "daily_activity",
        "other"
      ]
    },
    "met_code": {
      "type": ["string", "null"],
      "description": "Compendium of Physical Activities 2011 code"
    },
    "met_value": {
      "type": ["number", "null"],
      "minimum": 0.5,
      "maximum": 25
    },
    "intensity": {
      "type": "string",
      "enum": ["light", "moderate", "vigorous", "unknown"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "steps": {"type": ["integer", "null"], "minimum": 0},
        "distance_m": {"type": ["number", "null"], "minimum": 0},
        "kcal_burned": {"type": ["number", "null"], "minimum": 0},
        "hr_avg_bpm": {"type": ["integer", "null"], "minimum": 30, "maximum": 230},
        "hr_max_bpm": {"type": ["integer", "null"], "minimum": 30, "maximum": 230},
        "elevation_gain_m": {"type": ["number", "null"]},
        "pace_min_per_km": {"type": ["number", "null"], "minimum": 0},
        "_missing_fields": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "input_method": {
      "type": "string",
      "enum": ["manual", "wearable_sync", "gps_tracked", "import"]
    },
    "device_source": {
      "type": ["string", "null"],
      "enum": [
        null,
        "apple_health",
        "samsung_health",
        "google_fit",
        "garmin",
        "fitbit",
        "strava",
        "other"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
